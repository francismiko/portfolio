---
import Header from "@/components/shared/Header.astro";
import { resume } from "@/content/resume";
import { getLangFromUrl, useTranslations } from "@/i18n/ui";
import Layout from "@/layouts/Layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Portfolio" description={resume.personal.bio[lang]}>
	<Header />

	<main class="pt-16">
		<!-- Hero Section -->
		<section class="min-h-screen flex items-center justify-center px-6">
			<div class="max-w-3xl text-center">
				<p class="text-lg text-black/60 dark:text-white/60 mb-4">
					{t("hero.greeting")}
				</p>
				<h1 class="text-5xl md:text-7xl font-bold mb-6">
					{resume.personal.name[lang]}
				</h1>
				<p class="text-2xl md:text-3xl text-[--color-primary] font-medium mb-8">
					{resume.personal.title[lang]}
				</p>
				<p class="text-lg text-black/70 dark:text-white/70 mb-12 max-w-xl mx-auto">
					{resume.personal.bio[lang]}
				</p>
				<a
					href="#about"
					class="inline-flex items-center gap-2 px-8 py-4 rounded-full embossed-raised hover:scale-105 transition-transform cursor-pointer font-medium"
				>
					{t("hero.cta")}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 20 20"
						fill="currentColor"
						class="w-5 h-5"
					>
						<path
							fill-rule="evenodd"
							d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z"
							clip-rule="evenodd"></path>
					</svg>
				</a>
			</div>
		</section>

		<!-- About Section -->
		<section id="about" class="py-24 px-6 bg-black/[0.02] dark:bg-white/[0.02]">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-4xl font-bold mb-12 text-center">{t("about.title")}</h2>
				<div class="embossed-raised rounded-2xl p-8">
					<p class="text-lg text-black/70 dark:text-white/70 leading-relaxed">
						{resume.personal.bio[lang]}
					</p>
				</div>
			</div>
		</section>

		<!-- Skills Section -->
		<section id="skills" class="py-24 px-6">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-4xl font-bold mb-12 text-center">{t("skills.title")}</h2>
				<div class="grid md:grid-cols-3 gap-6">
					{resume.skills.map((skill) => (
						<div class="embossed-raised rounded-2xl p-6">
							<h3 class="text-xl font-semibold mb-4">{skill.category[lang]}</h3>
							<div class="flex flex-wrap gap-2">
								{skill.items.map((item) => (
									<span class="px-3 py-1 rounded-full bg-black/[0.04] dark:bg-white/[0.06] text-sm">
										{item}
									</span>
								))}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Projects Section -->
		<section id="projects" class="py-24 px-6 bg-black/[0.02] dark:bg-white/[0.02]">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-4xl font-bold mb-12 text-center">{t("projects.title")}</h2>
				<div class="grid md:grid-cols-2 gap-6">
					{resume.projects.map((project) => (
						<div class="embossed-raised rounded-2xl p-6">
							<h3 class="text-xl font-semibold mb-2">{project.name}</h3>
							<p class="text-black/60 dark:text-white/60 mb-4">
								{project.description[lang]}
							</p>
							<div class="flex flex-wrap gap-2 mb-4">
								{project.tech.map((tech) => (
									<span class="px-2 py-1 rounded bg-[--color-primary]/10 text-[--color-primary] text-xs font-medium">
										{tech}
									</span>
								))}
							</div>
							<div class="flex gap-4">
								{project.url && (
									<a
										href={project.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-sm text-[--color-primary] hover:underline"
									>
										Live Demo
									</a>
								)}
								{project.github && (
									<a
										href={project.github}
										target="_blank"
										rel="noopener noreferrer"
										class="text-sm text-[--color-primary] hover:underline"
									>
										GitHub
									</a>
								)}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Experience Section -->
		<section id="experience" class="py-24 px-6">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-4xl font-bold mb-12 text-center">{t("experience.title")}</h2>
				<div class="space-y-6">
					{resume.experience.map((exp) => (
						<div class="embossed-raised rounded-2xl p-6">
							<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
								<div>
									<h3 class="text-xl font-semibold">{exp.company}</h3>
									<p class="text-[--color-primary]">{exp.title[lang]}</p>
								</div>
								<p class="text-black/50 dark:text-white/50 text-sm">{exp.period}</p>
							</div>
							<p class="text-black/70 dark:text-white/70 mb-4">{exp.description[lang]}</p>
							<ul class="space-y-2">
								{exp.highlights.map((highlight) => (
									<li class="flex items-start gap-2 text-sm text-black/60 dark:text-white/60">
										<span class="text-[--color-primary] mt-1">•</span>
										{highlight[lang]}
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contact" class="py-24 px-6 bg-black/[0.02] dark:bg-white/[0.02]">
			<div class="max-w-5xl mx-auto text-center">
				<h2 class="text-4xl font-bold mb-12">{t("contact.title")}</h2>
				<div class="embossed-raised rounded-2xl p-8 max-w-md mx-auto">
					<p class="text-lg mb-6">{resume.personal.email}</p>
					<div class="flex justify-center gap-4">
						{resume.personal.links.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								class="px-6 py-3 rounded-full embossed-raised hover:scale-105 transition-transform"
							>
								{link.label}
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="py-8 px-6 border-t border-black/[0.04] dark:border-white/[0.06]">
			<div class="max-w-5xl mx-auto text-center text-sm text-black/50 dark:text-white/50">
				© {new Date().getFullYear()} {resume.personal.name[lang]}. {t("footer.copyright")}.
			</div>
		</footer>
	</main>
</Layout>
